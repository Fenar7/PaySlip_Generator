# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
# For local dev: run `supabase start` and use the output values
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Database ─────────────────────────────────────────────────────────────────
# For local dev: Supabase CLI provides this automatically
# For production: Use the pooled connection (port 6543) as DATABASE_URL
#   and the direct connection (port 5432) as DIRECT_URL
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# ─── Brevo (Supabase Auth email delivery) ─────────────────────────────────────
# Brevo SMTP is used by Supabase Auth to send verification, reset-password, and OTP emails.
# 1. Log in at https://app.brevo.com
# 2. Go to SMTP & API → SMTP → Generate a new SMTP key
# 3. BREVO_SMTP_USER = your Brevo account login email
# 4. BREVO_SMTP_KEY  = the generated SMTP key (starts with "xkeysib-...")
# These are read by supabase/config.toml via env() — NOT used directly by the Next.js app.
BREVO_SMTP_USER="your-brevo-login@example.com"
BREVO_SMTP_KEY="xkeysib-your-brevo-smtp-key"

# ─── Resend (app-level transactional email — optional) ────────────────────────
# Used for future app emails (invoices, notifications). Separate from auth emails.
# Leave empty in dev — emails will be logged to console instead
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@slipwise.app"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Slipwise One"
