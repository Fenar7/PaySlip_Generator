# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Use Neon for Vercel hosting:
# https://neon.tech (free tier available)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/slipwise?sslmode=require"

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional — leave empty to disable Google sign-in) ──────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com
# Leave empty in dev — emails will be logged to console instead
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@slipwise.app"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Slipwise One"
