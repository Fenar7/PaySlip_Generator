generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User Profile (linked to Supabase auth.users via UUID) ───────────────────

model Profile {
  id        String   @id @db.Uuid // matches auth.users.id
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              Member[]
  auditActorLogs       AuditLog[]            @relation("AuditActor")
  auditRepLogs         AuditLog[]            @relation("AuditRepresented")
  referrals            Referral[]
  onboardingProgress   OnboardingProgress?
  pushSubscriptions    PushSubscription[]
  orgPreferences       UserOrgPreference[]

  @@map("profiles")
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members         Member[]
  invitations     Invitation[]
  branding        BrandingProfile?
  defaults        OrgDefaults?
  customers       Customer[]
  vendors         Vendor[]
  employees       Employee[]
  invoices        Invoice[]
  vouchers        Voucher[]
  salarySlips     SalarySlip[]
  salaryPresets   SalaryPreset[]
  attachments     FileAttachment[]
  reportSnapshots ReportSnapshot[]
  proxyGrants     ProxyGrant[]
  auditLogs       AuditLog[]
  subscription    Subscription?
  usageRecords    UsageRecord[]
  storageUsage    StorageUsage[]
  sendLogs        SendLog[]
  sharedDocuments SharedDocument[]
  virtualAccounts     CustomerVirtualAccount[]
  unmatchedPayments   UnmatchedPayment[]
  billingInvoices     BillingInvoice[]
  apiKeys             ApiKey[]
  webhookEndpoints    ApiWebhookEndpoint[]
  apiRequestLogs      ApiRequestLog[]
  ssoConfig           SsoConfig?
  orgPreferences      UserOrgPreference[]
  orgDomain           OrgDomain?
  whiteLabel          OrgWhiteLabel?
  emailDomains        OrgEmailDomain[]
  ocrJobs             OcrJob[]
  integrations        OrgIntegration[]

  @@map("organization")
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @db.Uuid
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String   @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// ─── Custom domain models ──────────────────────────────────────────────────────

model BrandingProfile {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoUrl        String?
  accentColor    String   @default("#dc2626")
  fontFamily     String   @default("Inter")
  fontColor      String   @default("#1a1a1a")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("branding_profile")
}

model OrgDefaults {
  id             String @id @default(cuid())
  organizationId String @unique

  bankName        String?
  bankAccount     String?
  bankIFSC        String?
  taxId           String?
  gstin           String?
  businessAddress String?

  invoicePrefix     String @default("INV")
  invoiceCounter    Int    @default(1)
  voucherPrefix     String @default("VCH")
  voucherCounter    Int    @default(1)
  salarySlipPrefix  String @default("SAL")
  salarySlipCounter Int    @default(1)

  defaultInvoiceTemplate String @default("minimal")
  defaultVoucherTemplate String @default("minimal-office")
  defaultSlipTemplate    String @default("modern-premium")

  upiVpa         String?
  gstStateCode   String?
  panNumber      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_defaults")
}

// ─── Master Data Models ─────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  taxId          String?
  gstin          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  virtualAccounts CustomerVirtualAccount[]

  @@index([organizationId])
  @@map("customer")
}

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  taxId          String?
  gstin          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]

  @@index([organizationId])
  @@map("vendor")
}

model Employee {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  employeeId     String?
  designation    String?
  department     String?
  bankName       String?
  bankAccount    String?
  bankIFSC       String?
  panNumber      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salarySlips  SalarySlip[]

  @@index([organizationId])
  @@map("employee")
}

// ─── Document Models ────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  VIEWED
  DUE
  PARTIALLY_PAID
  PAID
  OVERDUE
  DISPUTED
  CANCELLED
  REISSUED
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String?
  invoiceNumber  String
  invoiceDate    String
  dueDate        String?
  status         InvoiceStatus @default(DRAFT)
  formData       Json
  totalAmount    Float         @default(0)
  notes          String?
  originalId     String?
  issuedAt       DateTime?
  paidAt         DateTime?
  overdueAt      DateTime?
  reissueReason           String?
  razorpayPaymentLinkId   String?
  razorpayPaymentLinkUrl  String?
  paymentLinkExpiresAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  archivedAt     DateTime?

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer?             @relation(fields: [customerId], references: [id])
  original       Invoice?              @relation("InvoiceReissue", fields: [originalId], references: [id])
  reissues       Invoice[]             @relation("InvoiceReissue")
  lineItems      InvoiceLineItem[]
  attachments    FileAttachment[]      @relation("InvoiceAttachments")
  stateEvents    InvoiceStateEvent[]
  payments       InvoicePayment[]
  proofs         InvoiceProof[]
  publicTokens   PublicInvoiceToken[]
  tickets        InvoiceTicket[]
  scheduledSends ScheduledSend[]
  recurringRule  RecurringInvoiceRule? @relation("RecurringBase")
  generatedFrom  RecurringInvoiceRule? @relation("RecurringGenerated", fields: [generatedFromRuleId], references: [id])
  generatedFromRuleId String?
  approvalRequests ApprovalRequest[]   @relation("InvoiceApprovals")

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@map("invoice")
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  taxRate     Float  @default(0)
  discount    Float  @default(0)
  amount      Float  @default(0)
  sortOrder   Int    @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_item")
}

model Voucher {
  id             String    @id @default(cuid())
  organizationId String
  vendorId       String?
  voucherNumber  String
  voucherDate    String
  type           String    @default("payment")
  status         String    @default("draft")
  formData       Json
  totalAmount    Float     @default(0)
  isMultiLine    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor?          @relation(fields: [vendorId], references: [id])
  lines        VoucherLine[]
  attachments  FileAttachment[] @relation("VoucherAttachments")
  approvalRequests ApprovalRequest[] @relation("VoucherApprovals")

  @@unique([organizationId, voucherNumber])
  @@index([organizationId, status])
  @@map("voucher")
}

model VoucherLine {
  id          String  @id @default(cuid())
  voucherId   String
  description String
  date        String?
  time        String?
  amount      Float   @default(0)
  category    String?
  sortOrder   Int     @default(0)

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@map("voucher_line")
}

model SalarySlip {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String?
  slipNumber     String
  month          Int
  year           Int
  status         String    @default("draft")
  formData       Json
  grossPay       Float     @default(0)
  netPay         Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee?         @relation(fields: [employeeId], references: [id])
  components   SalaryComponent[]
  attachments  FileAttachment[]  @relation("SalarySlipAttachments")
  approvalRequests ApprovalRequest[] @relation("SalarySlipApprovals")

  @@unique([organizationId, slipNumber])
  @@index([organizationId, status])
  @@map("salary_slip")
}

model SalaryComponent {
  id           String @id @default(cuid())
  salarySlipId String
  label        String
  amount       Float  @default(0)
  type         String
  sortOrder    Int    @default(0)

  salarySlip SalarySlip @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)

  @@map("salary_component")
}

model FileAttachment {
  id             String   @id @default(cuid())
  organizationId String
  entityType     String
  entityId       String
  fileName       String
  storageKey     String
  mimeType       String
  size           Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invoice    Invoice?    @relation("InvoiceAttachments", fields: [entityId], references: [id], map: "file_attachment_invoice_fkey")
  voucher    Voucher?    @relation("VoucherAttachments", fields: [entityId], references: [id], map: "file_attachment_voucher_fkey")
  salarySlip SalarySlip? @relation("SalarySlipAttachments", fields: [entityId], references: [id], map: "file_attachment_salary_slip_fkey")

  @@index([organizationId, entityType, entityId])
  @@map("file_attachment")
}

model SalaryPreset {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  components     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("salary_preset")
}

// ─── Phase 4: SW Pay — Invoice Lifecycle ──────────────────────────────────────

model InvoiceStateEvent {
  id         String   @id @default(cuid())
  invoiceId  String
  fromStatus String
  toStatus   String
  actorId    String?  @db.Uuid
  actorName  String?
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_state_event")
}

model InvoicePayment {
  id         String   @id @default(cuid())
  invoiceId  String
  orgId      String
  amount     Float
  currency   String   @default("INR")
  paidAt     DateTime @default(now())
  method     String?
  note       String?
  isPartial  Boolean  @default(false)
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_payment")
}

enum ProofReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model InvoiceProof {
  id               String            @id @default(cuid())
  invoiceId        String
  fileUrl          String
  fileName         String
  amount           Float             @default(0)
  paymentDate      String?
  paymentMethod    String?
  uploadedByToken  String?
  uploadedByUserId String?           @db.Uuid
  reviewStatus     ProofReviewStatus @default(PENDING)
  reviewNote       String?
  reviewedById     String?           @db.Uuid
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_proof")
}

model PublicInvoiceToken {
  id             String    @id @default(cuid())
  invoiceId      String
  orgId          String
  token          String    @unique @default(cuid())
  expiresAt      DateTime?
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("public_invoice_token")
}

// ─── Phase 5: SW Flow — Ticketing ─────────────────────────────────────────────

enum TicketCategory {
  BILLING_QUERY
  AMOUNT_DISPUTE
  MISSING_ITEM
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model InvoiceTicket {
  id              String         @id @default(cuid())
  invoiceId       String
  orgId           String
  submitterToken  String?
  submitterName   String
  submitterEmail  String
  category        TicketCategory @default(OTHER)
  description     String
  status          TicketStatus   @default(OPEN)
  assigneeId      String?        @db.Uuid
  createdAt       DateTime       @default(now())
  resolvedAt      DateTime?

  invoice Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([invoiceId])
  @@index([orgId, status])
  @@map("invoice_ticket")
}

model TicketReply {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?  @db.Uuid
  authorName String
  isInternal Boolean  @default(false)
  message    String
  createdAt  DateTime @default(now())

  ticket InvoiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_reply")
}

// ─── Phase 5: SW Flow — Approvals ─────────────────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id            String         @id @default(cuid())
  docType       String
  docId         String
  orgId         String
  requestedById String         @db.Uuid
  requestedByName String?
  approverId    String?        @db.Uuid
  approverName  String?
  status        ApprovalStatus @default(PENDING)
  note          String?
  createdAt     DateTime       @default(now())
  decidedAt     DateTime?

  invoice    Invoice?    @relation("InvoiceApprovals", fields: [docId], references: [id], map: "approval_invoice_fkey")
  voucher    Voucher?    @relation("VoucherApprovals", fields: [docId], references: [id], map: "approval_voucher_fkey")
  salarySlip SalarySlip? @relation("SalarySlipApprovals", fields: [docId], references: [id], map: "approval_salary_slip_fkey")

  @@index([orgId, status])
  @@index([docType, docId])
  @@map("approval_request")
}

// ─── Phase 5: SW Flow — Notifications ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  orgId     String
  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([orgId])
  @@map("notification")
}

// ─── Phase 5: SW Flow — Activity Feed ─────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  orgId     String
  actorId   String?  @db.Uuid
  actorName String
  event     String
  docType   String?
  docId     String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@map("activity_log")
}

// ─── Phase 5: SW Flow — Scheduled Send ────────────────────────────────────────

enum SendStatus {
  PENDING
  SENT
  FAILED
}

model ScheduledSend {
  id             String     @id @default(cuid())
  invoiceId      String
  orgId          String
  recipientEmail String
  scheduledAt    DateTime
  status         SendStatus @default(PENDING)
  sentAt         DateTime?
  failReason     String?
  createdAt      DateTime   @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([scheduledAt, status])
  @@map("scheduled_send")
}

// ─── Phase 5: SW Flow — Recurring Invoice ─────────────────────────────────────

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model RecurringInvoiceRule {
  id             String             @id @default(cuid())
  orgId          String
  baseInvoiceId  String             @unique
  frequency      RecurringFrequency @default(MONTHLY)
  nextRunAt      DateTime
  endDate        DateTime?
  autoSend       Boolean            @default(false)
  status         RecurringStatus    @default(ACTIVE)
  runsCount      Int                @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime           @default(now())

  baseInvoice      Invoice   @relation("RecurringBase", fields: [baseInvoiceId], references: [id], onDelete: Cascade)
  generatedInvoices Invoice[] @relation("RecurringGenerated")

  @@index([orgId, status])
  @@index([nextRunAt, status])
  @@map("recurring_invoice_rule")
}

// ─── Phase 5: SW Flow — Job Log ───────────────────────────────────────────────

model JobLog {
  id           String    @id @default(cuid())
  jobName      String
  jobId        String?
  orgId        String?
  status       String    @default("pending")
  invoiceId    String?
  errorMessage String?
  payload      Json?
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  nextRetryAt  DateTime?
  triggeredAt  DateTime  @default(now())
  completedAt  DateTime?
  error        String?

  @@index([jobName, status])
  @@index([orgId, status])
  @@index([nextRetryAt, status])
  @@map("job_log")
}

// ─── Phase 6: SW Intel — Report Snapshots ─────────────────────────────────────

model ReportSnapshot {
  id           String    @id @default(cuid())
  orgId        String
  reportType   String
  filters      Json
  rowCount     Int
  generatedAt  DateTime  @default(now())
  downloadedAt DateTime?
  createdBy    String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, reportType])
  @@map("report_snapshot")
}

// ─── Phase 7: Proxy & Audit ───────────────────────────────────────────────────

enum ProxyStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model ProxyGrant {
  id            String      @id @default(cuid())
  orgId         String
  actorId       String      @db.Uuid
  representedId String      @db.Uuid
  scope         String[]
  reason        String
  grantedBy     String      @db.Uuid
  expiresAt     DateTime
  status        ProxyStatus @default(ACTIVE)
  revokedAt     DateTime?
  revokedBy     String?     @db.Uuid
  createdAt     DateTime    @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([actorId, status])
  @@map("proxy_grant")
}

model AuditLog {
  id            String   @id @default(cuid())
  orgId         String
  actorId       String   @db.Uuid
  representedId String?  @db.Uuid
  proxyGrantId  String?
  action        String
  entityType    String?
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor         Profile      @relation("AuditActor", fields: [actorId], references: [id])
  represented   Profile?     @relation("AuditRepresented", fields: [representedId], references: [id])

  @@index([orgId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_log")
}

// ─── Phase 10: Storage Usage Tracking ─────────────────────────────────────────

model StorageUsage {
  id             String   @id @default(cuid())
  orgId          String
  category       String   // "export" | "proof" | "attachment" | "pixel"
  sizeBytes      BigInt   @default(0)
  fileCount      Int      @default(0)
  lastUpdatedAt  DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, category])
  @@index([orgId])
  @@map("storage_usage")
}

// ─── Phase 10: Send Log ───────────────────────────────────────────────────────

model SendLog {
  id           String   @id @default(cuid())
  orgId        String
  type         String   // "invoice_send" | "scheduled_send" | "reminder" | "notification"
  recipientEmail String
  subject      String?
  status       String   @default("sent") // "sent" | "failed" | "bounced"
  errorMessage String?
  docType      String?  // "invoice" | "voucher" | "salary_slip"
  docId        String?
  sentAt       DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, type])
  @@index([orgId, sentAt])
  @@map("send_log")
}

// ─── Phase 11: Subscription & Billing ─────────────────────────────────────────

model Subscription {
  id                  String    @id @default(cuid())
  orgId               String    @unique
  planId              String    @default("free")
  status              String    @default("trialing")
  billingInterval     String?
  razorpayCustomerId  String?   @unique
  razorpaySubId       String?   @unique
  razorpayPlanId      String?
  trialEndsAt         DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean   @default(false)
  cancelledAt         DateTime?
  pausedAt            DateTime?
  pausedUntil         DateTime?
  pauseReason         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model UsageRecord {
  id          String   @id @default(cuid())
  orgId       String
  resource    String
  periodMonth String
  periodDay   String?
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, resource, periodMonth])
  @@index([orgId, periodMonth])
  @@map("usage_record")
}

model RazorpayEvent {
  id          String   @id
  type        String
  payload     Json
  processedAt DateTime @default(now())

  @@index([type])
  @@index([processedAt])
  @@map("razorpay_event")
}

// ─── Phase 11: Referral System ────────────────────────────────────────────────

model Referral {
  id              String    @id @default(cuid())
  referrerId      String    @db.Uuid
  referredOrgId   String?
  referralCode    String    @unique
  status          String    @default("pending")
  creditApplied   Boolean   @default(false)
  referrerCredit  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  convertedAt     DateTime?
  creditedAt      DateTime?

  referrer Profile @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referralCode])
  @@map("referral")
}

// ─── Phase 11: Document Sharing ───────────────────────────────────────────────

model SharedDocument {
  id            String    @id @default(cuid())
  orgId         String
  docType       String
  docId         String
  shareToken    String    @unique
  expiresAt     DateTime?
  viewCount     Int       @default(0)
  downloadCount Int       @default(0)
  createdBy     String    @db.Uuid
  createdAt     DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([shareToken])
  @@index([orgId, docType, docId])
  @@map("shared_document")
}

// ─── Phase 11: Onboarding Progress ───────────────────────────────────────────

model OnboardingProgress {
  id                  String    @id @default(cuid())
  userId              String    @unique @db.Uuid
  accountCreated      Boolean   @default(true)
  emailVerified       Boolean   @default(false)
  orgSetup            Boolean   @default(false)
  firstDocCreated     Boolean   @default(false)
  firstDocExported    Boolean   @default(false)
  teamMemberInvited   Boolean   @default(false)
  recurringSetup      Boolean   @default(false)
  completedAt         DateTime?
  dismissedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

// ─── Phase 12: Razorpay Payment Links & Smart Collect ─────────────────────────

model CustomerVirtualAccount {
  id              String    @id @default(cuid())
  orgId           String
  customerId      String
  razorpayVaId    String    @unique
  accountNumber   String
  ifsc            String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  closedAt        DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([orgId, customerId])
  @@map("customer_virtual_account")
}

model UnmatchedPayment {
  id                String    @id @default(cuid())
  orgId             String
  virtualAccountId  String
  amountPaise       BigInt
  payerName         String?
  payerAccount      String?
  payerIfsc         String?
  razorpayPaymentId String
  status            String    @default("unmatched")
  matchedInvoiceId  String?
  receivedAt        DateTime  @default(now())
  resolvedAt        DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("unmatched_payment")
}

model BillingInvoice {
  id                  String   @id @default(cuid())
  orgId               String
  razorpayInvoiceId   String?  @unique
  razorpayPaymentId   String?
  planId              String
  amountPaise         BigInt
  currency            String   @default("INR")
  periodStart         DateTime
  periodEnd           DateTime
  status              String   @default("paid")
  pdfUrl              String?
  createdAt           DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("billing_invoice")
}

// ─── Phase 12: API Platform ──────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdBy   String    @db.Uuid
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requestLogs  ApiRequestLog[]

  @@index([orgId, isActive])
  @@index([keyHash])
  @@map("api_key")
}

model ApiWebhookEndpoint {
  id              String    @id @default(cuid())
  orgId           String
  url             String
  events          String[]
  secretHash      String
  isActive        Boolean   @default(true)
  description     String?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  lastDeliveredAt DateTime?

  organization Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries   ApiWebhookDelivery[]

  @@index([orgId, isActive])
  @@map("api_webhook_endpoint")
}

model ApiWebhookDelivery {
  id              String   @id @default(cuid())
  endpointId      String
  eventType       String
  payload         Json
  responseStatus  Int?
  responseBody    String?
  durationMs      Int?
  success         Boolean
  attempt         Int      @default(1)
  deliveredAt     DateTime @default(now())

  endpoint ApiWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, deliveredAt])
  @@map("api_webhook_delivery")
}

model ApiRequestLog {
  id         String   @id @default(cuid())
  orgId      String
  apiKeyId   String?
  method     String
  path       String
  statusCode Int
  durationMs Int?
  ip         String?
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  apiKey       ApiKey?      @relation(fields: [apiKeyId], references: [id])

  @@index([orgId, createdAt])
  @@index([apiKeyId, createdAt])
  @@map("api_request_log")
}

// ─── Phase 12: Enterprise Features ───────────────────────────────────────────

model SsoConfig {
  id              String    @id @default(cuid())
  orgId           String    @unique
  provider        String
  metadataUrl     String?
  metadataXml     String?   @db.Text
  acsUrl          String
  entityId        String
  ssoEnforced     Boolean   @default(false)
  isActive        Boolean   @default(true)
  testedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("sso_config")
}

model UserOrgPreference {
  userId      String   @id @db.Uuid
  activeOrgId String
  updatedAt   DateTime @updatedAt

  user Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [activeOrgId], references: [id], onDelete: Cascade)

  @@map("user_org_preference")
}

model OrgDomain {
  id           String    @id @default(cuid())
  orgId        String    @unique
  domain       String    @unique
  verified     Boolean   @default(false)
  verifyToken  String
  createdAt    DateTime  @default(now())
  verifiedAt   DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_domain")
}

model OrgWhiteLabel {
  id              String   @id @default(cuid())
  orgId           String   @unique
  removeBranding  Boolean  @default(false)
  emailFromName   String?
  emailReplyTo    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_white_label")
}

model OrgEmailDomain {
  id          String   @id @default(cuid())
  orgId       String
  emailDomain String
  defaultRole String   @default("viewer")
  autoJoin    Boolean  @default(false)
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, emailDomain])
  @@map("org_email_domain")
}

// ─── Phase 13: AI Features ───────────────────────────────────────────────────

model OcrJob {
  id            String    @id @default(cuid())
  orgId         String
  status        String    @default("pending")
  inputS3Key    String
  extractedData Json?
  confidence    Float?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("ocr_job")
}

// ─── Phase 13: Third-Party Integrations ──────────────────────────────────────

model OrgIntegration {
  id             String    @id @default(cuid())
  orgId          String
  provider       String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  externalOrgId  String?
  config         Json?
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@map("org_integration")
}

// ─── Phase 13: Push Notifications ────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  endpoint  String   @unique
  keys      Json
  userAgent String?
  createdAt DateTime @default(now())

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscription")
}
