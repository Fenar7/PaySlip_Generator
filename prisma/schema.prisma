generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User Profile (linked to Supabase auth.users via UUID) ───────────────────

model Profile {
  id        String   @id @db.Uuid // matches auth.users.id
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]

  @@map("profiles")
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members     Member[]
  invitations Invitation[]
  branding    BrandingProfile?
  defaults    OrgDefaults?

  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  userId         String       @db.Uuid
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  inviterId      String       @db.Uuid

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// ─── Custom domain models ──────────────────────────────────────────────────────

model BrandingProfile {
  id             String       @id @default(cuid())
  organizationId String       @unique
  logoUrl        String?
  accentColor    String       @default("#dc2626")
  fontFamily     String       @default("Inter")
  fontColor      String       @default("#1a1a1a")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("branding_profile")
}

model OrgDefaults {
  id                     String       @id @default(cuid())
  organizationId         String       @unique

  bankName               String?
  bankAccount            String?
  bankIFSC               String?
  taxId                  String?
  gstin                  String?
  businessAddress        String?

  invoicePrefix          String       @default("INV")
  invoiceCounter         Int          @default(1)
  voucherPrefix          String       @default("VCH")
  voucherCounter         Int          @default(1)
  salarySlipPrefix       String       @default("SAL")
  salarySlipCounter      Int          @default(1)

  defaultInvoiceTemplate String       @default("minimal")
  defaultVoucherTemplate String       @default("minimal-office")
  defaultSlipTemplate    String       @default("modern-premium")

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_defaults")
}

