generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User Profile (linked to Supabase auth.users via UUID) ───────────────────

model Profile {
  id        String   @id @db.Uuid // matches auth.users.id
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]

  @@map("profiles")
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members       Member[]
  invitations   Invitation[]
  branding      BrandingProfile?
  defaults      OrgDefaults?
  customers     Customer[]
  vendors       Vendor[]
  employees     Employee[]
  invoices      Invoice[]
  vouchers      Voucher[]
  salarySlips   SalarySlip[]
  salaryPresets SalaryPreset[]
  attachments   FileAttachment[]

  @@map("organization")
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @db.Uuid
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String   @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// ─── Custom domain models ──────────────────────────────────────────────────────

model BrandingProfile {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoUrl        String?
  accentColor    String   @default("#dc2626")
  fontFamily     String   @default("Inter")
  fontColor      String   @default("#1a1a1a")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("branding_profile")
}

model OrgDefaults {
  id             String @id @default(cuid())
  organizationId String @unique

  bankName        String?
  bankAccount     String?
  bankIFSC        String?
  taxId           String?
  gstin           String?
  businessAddress String?

  invoicePrefix     String @default("INV")
  invoiceCounter    Int    @default(1)
  voucherPrefix     String @default("VCH")
  voucherCounter    Int    @default(1)
  salarySlipPrefix  String @default("SAL")
  salarySlipCounter Int    @default(1)

  defaultInvoiceTemplate String @default("minimal")
  defaultVoucherTemplate String @default("minimal-office")
  defaultSlipTemplate    String @default("modern-premium")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_defaults")
}

// ─── Master Data Models ─────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  taxId          String?
  gstin          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([organizationId])
  @@map("customer")
}

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  taxId          String?
  gstin          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]

  @@index([organizationId])
  @@map("vendor")
}

model Employee {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  employeeId     String?
  designation    String?
  department     String?
  bankName       String?
  bankAccount    String?
  bankIFSC       String?
  panNumber      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salarySlips  SalarySlip[]

  @@index([organizationId])
  @@map("employee")
}

// ─── Document Models ────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  VIEWED
  DUE
  PARTIALLY_PAID
  PAID
  OVERDUE
  DISPUTED
  CANCELLED
  REISSUED
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String?
  invoiceNumber  String
  invoiceDate    String
  dueDate        String?
  status         InvoiceStatus @default(DRAFT)
  formData       Json
  totalAmount    Float         @default(0)
  notes          String?
  originalId     String?
  issuedAt       DateTime?
  paidAt         DateTime?
  overdueAt      DateTime?
  reissueReason  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  archivedAt     DateTime?

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer?             @relation(fields: [customerId], references: [id])
  original       Invoice?              @relation("InvoiceReissue", fields: [originalId], references: [id])
  reissues       Invoice[]             @relation("InvoiceReissue")
  lineItems      InvoiceLineItem[]
  attachments    FileAttachment[]      @relation("InvoiceAttachments")
  stateEvents    InvoiceStateEvent[]
  payments       InvoicePayment[]
  proofs         InvoiceProof[]
  publicTokens   PublicInvoiceToken[]
  tickets        InvoiceTicket[]
  scheduledSends ScheduledSend[]
  recurringRule  RecurringInvoiceRule? @relation("RecurringBase")
  generatedFrom  RecurringInvoiceRule? @relation("RecurringGenerated", fields: [generatedFromRuleId], references: [id])
  generatedFromRuleId String?
  approvalRequests ApprovalRequest[]   @relation("InvoiceApprovals")

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@map("invoice")
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  taxRate     Float  @default(0)
  discount    Float  @default(0)
  amount      Float  @default(0)
  sortOrder   Int    @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_item")
}

model Voucher {
  id             String    @id @default(cuid())
  organizationId String
  vendorId       String?
  voucherNumber  String
  voucherDate    String
  type           String    @default("payment")
  status         String    @default("draft")
  formData       Json
  totalAmount    Float     @default(0)
  isMultiLine    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor?          @relation(fields: [vendorId], references: [id])
  lines        VoucherLine[]
  attachments  FileAttachment[] @relation("VoucherAttachments")
  approvalRequests ApprovalRequest[] @relation("VoucherApprovals")

  @@unique([organizationId, voucherNumber])
  @@index([organizationId, status])
  @@map("voucher")
}

model VoucherLine {
  id          String  @id @default(cuid())
  voucherId   String
  description String
  date        String?
  time        String?
  amount      Float   @default(0)
  category    String?
  sortOrder   Int     @default(0)

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@map("voucher_line")
}

model SalarySlip {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String?
  slipNumber     String
  month          Int
  year           Int
  status         String    @default("draft")
  formData       Json
  grossPay       Float     @default(0)
  netPay         Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee?         @relation(fields: [employeeId], references: [id])
  components   SalaryComponent[]
  attachments  FileAttachment[]  @relation("SalarySlipAttachments")
  approvalRequests ApprovalRequest[] @relation("SalarySlipApprovals")

  @@unique([organizationId, slipNumber])
  @@index([organizationId, status])
  @@map("salary_slip")
}

model SalaryComponent {
  id           String @id @default(cuid())
  salarySlipId String
  label        String
  amount       Float  @default(0)
  type         String
  sortOrder    Int    @default(0)

  salarySlip SalarySlip @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)

  @@map("salary_component")
}

model FileAttachment {
  id             String   @id @default(cuid())
  organizationId String
  entityType     String
  entityId       String
  fileName       String
  storageKey     String
  mimeType       String
  size           Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invoice    Invoice?    @relation("InvoiceAttachments", fields: [entityId], references: [id], map: "file_attachment_invoice_fkey")
  voucher    Voucher?    @relation("VoucherAttachments", fields: [entityId], references: [id], map: "file_attachment_voucher_fkey")
  salarySlip SalarySlip? @relation("SalarySlipAttachments", fields: [entityId], references: [id], map: "file_attachment_salary_slip_fkey")

  @@index([organizationId, entityType, entityId])
  @@map("file_attachment")
}

model SalaryPreset {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  components     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("salary_preset")
}

// ─── Phase 4: SW Pay — Invoice Lifecycle ──────────────────────────────────────

model InvoiceStateEvent {
  id         String   @id @default(cuid())
  invoiceId  String
  fromStatus String
  toStatus   String
  actorId    String?  @db.Uuid
  actorName  String?
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_state_event")
}

model InvoicePayment {
  id         String   @id @default(cuid())
  invoiceId  String
  orgId      String
  amount     Float
  currency   String   @default("INR")
  paidAt     DateTime @default(now())
  method     String?
  note       String?
  isPartial  Boolean  @default(false)
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_payment")
}

enum ProofReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model InvoiceProof {
  id               String            @id @default(cuid())
  invoiceId        String
  fileUrl          String
  fileName         String
  amount           Float             @default(0)
  paymentDate      String?
  paymentMethod    String?
  uploadedByToken  String?
  uploadedByUserId String?           @db.Uuid
  reviewStatus     ProofReviewStatus @default(PENDING)
  reviewNote       String?
  reviewedById     String?           @db.Uuid
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_proof")
}

model PublicInvoiceToken {
  id             String    @id @default(cuid())
  invoiceId      String
  orgId          String
  token          String    @unique @default(cuid())
  expiresAt      DateTime?
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("public_invoice_token")
}

// ─── Phase 5: SW Flow — Ticketing ─────────────────────────────────────────────

enum TicketCategory {
  BILLING_QUERY
  AMOUNT_DISPUTE
  MISSING_ITEM
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model InvoiceTicket {
  id              String         @id @default(cuid())
  invoiceId       String
  orgId           String
  submitterToken  String?
  submitterName   String
  submitterEmail  String
  category        TicketCategory @default(OTHER)
  description     String
  status          TicketStatus   @default(OPEN)
  assigneeId      String?        @db.Uuid
  createdAt       DateTime       @default(now())
  resolvedAt      DateTime?

  invoice Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([invoiceId])
  @@index([orgId, status])
  @@map("invoice_ticket")
}

model TicketReply {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?  @db.Uuid
  authorName String
  isInternal Boolean  @default(false)
  message    String
  createdAt  DateTime @default(now())

  ticket InvoiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_reply")
}

// ─── Phase 5: SW Flow — Approvals ─────────────────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id            String         @id @default(cuid())
  docType       String
  docId         String
  orgId         String
  requestedById String         @db.Uuid
  requestedByName String?
  approverId    String?        @db.Uuid
  approverName  String?
  status        ApprovalStatus @default(PENDING)
  note          String?
  createdAt     DateTime       @default(now())
  decidedAt     DateTime?

  invoice    Invoice?    @relation("InvoiceApprovals", fields: [docId], references: [id], map: "approval_invoice_fkey")
  voucher    Voucher?    @relation("VoucherApprovals", fields: [docId], references: [id], map: "approval_voucher_fkey")
  salarySlip SalarySlip? @relation("SalarySlipApprovals", fields: [docId], references: [id], map: "approval_salary_slip_fkey")

  @@index([orgId, status])
  @@index([docType, docId])
  @@map("approval_request")
}

// ─── Phase 5: SW Flow — Notifications ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  orgId     String
  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([orgId])
  @@map("notification")
}

// ─── Phase 5: SW Flow — Activity Feed ─────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  orgId     String
  actorId   String?  @db.Uuid
  actorName String
  event     String
  docType   String?
  docId     String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@map("activity_log")
}

// ─── Phase 5: SW Flow — Scheduled Send ────────────────────────────────────────

enum SendStatus {
  PENDING
  SENT
  FAILED
}

model ScheduledSend {
  id             String     @id @default(cuid())
  invoiceId      String
  orgId          String
  recipientEmail String
  scheduledAt    DateTime
  status         SendStatus @default(PENDING)
  sentAt         DateTime?
  failReason     String?
  createdAt      DateTime   @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([scheduledAt, status])
  @@map("scheduled_send")
}

// ─── Phase 5: SW Flow — Recurring Invoice ─────────────────────────────────────

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model RecurringInvoiceRule {
  id             String             @id @default(cuid())
  orgId          String
  baseInvoiceId  String             @unique
  frequency      RecurringFrequency @default(MONTHLY)
  nextRunAt      DateTime
  endDate        DateTime?
  autoSend       Boolean            @default(false)
  status         RecurringStatus    @default(ACTIVE)
  runsCount      Int                @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime           @default(now())

  baseInvoice      Invoice   @relation("RecurringBase", fields: [baseInvoiceId], references: [id], onDelete: Cascade)
  generatedInvoices Invoice[] @relation("RecurringGenerated")

  @@index([orgId, status])
  @@index([nextRunAt, status])
  @@map("recurring_invoice_rule")
}

// ─── Phase 5: SW Flow — Job Log ───────────────────────────────────────────────

model JobLog {
  id          String    @id @default(cuid())
  jobName     String
  jobId       String?
  status      String    @default("pending")
  invoiceId   String?
  triggeredAt DateTime  @default(now())
  completedAt DateTime?
  error       String?

  @@index([jobName, status])
  @@map("job_log")
}
