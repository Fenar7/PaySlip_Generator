  POLITE
  FIRM
  URGENT
  ESCALATE
}

enum DunningLogStatus {
  SENT
  FAILED
  SKIPPED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  CONVERTED
}

enum ArrangementStatus {
  ACTIVE
