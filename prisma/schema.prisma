generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User Profile (linked to Supabase auth.users via UUID) ───────────────────

model Profile {
  id        String   @id @db.Uuid // matches auth.users.id
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             Member[]
  auditActorLogs      AuditLog[]           @relation("AuditActor")
  auditRepLogs        AuditLog[]           @relation("AuditRepresented")
  referrals           Referral[]
  onboardingProgress  OnboardingProgress?
  pushSubscriptions   PushSubscription[]
  orgPreferences      UserOrgPreference[]
  quotes              Quote[]
  arrangements        PaymentArrangement[]
  oauthAuthorizations OAuthAuthorization[]

  @@map("profiles")
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members                Member[]
  invitations            Invitation[]
  branding               BrandingProfile?
  defaults               OrgDefaults?
  customers              Customer[]
  vendors                Vendor[]
  employees              Employee[]
  invoices               Invoice[]
  vouchers               Voucher[]
  salarySlips            SalarySlip[]
  salaryPresets          SalaryPreset[]
  attachments            FileAttachment[]
  reportSnapshots        ReportSnapshot[]
  glAccounts             GlAccount[]
  fiscalPeriods          FiscalPeriod[]
  journalEntries         JournalEntry[]
  journalLines           JournalLine[]
  bankAccounts           BankAccount[]
  bankStatementImports   BankStatementImport[]
  bankTransactions       BankTransaction[]
  bankTransactionMatches BankTransactionMatch[]
  vendorBills            VendorBill[]
  vendorBillPayments     VendorBillPayment[]
  paymentRuns            PaymentRun[]
  closeRuns              CloseRun[]
  closeTasks             CloseTask[]
  proxyGrants            ProxyGrant[]
  auditLogs              AuditLog[]
  subscription           Subscription?
  usageRecords           UsageRecord[]
  storageUsage           StorageUsage[]
  sendLogs               SendLog[]
  sharedDocuments        SharedDocument[]
  virtualAccounts        CustomerVirtualAccount[]
  unmatchedPayments      UnmatchedPayment[]
  billingInvoices        BillingInvoice[]
  apiKeys                ApiKey[]
  webhookEndpoints       ApiWebhookEndpoint[]
  apiRequestLogs         ApiRequestLog[]
  ssoConfig              SsoConfig?
  orgPreferences         UserOrgPreference[]
  orgDomain              OrgDomain?
  whiteLabel             OrgWhiteLabel?
  emailDomains           OrgEmailDomain[]
  ocrJobs                OcrJob[]
  integrations           OrgIntegration[]
  dunningSequences       DunningSequence[]
  dunningLogs            DunningLog[]
  dunningOptOuts         DunningOptOut[]
  portalTokens           CustomerPortalToken[]
  portalAccessLogs       CustomerPortalAccessLog[]
  statements             CustomerStatement[]
  quotes                 Quote[]
  arrangements           PaymentArrangement[]
  tdsRecords             TdsRecord[]
  marketplaceTemplates   MarketplaceTemplate[]
  marketplacePurchases   MarketplacePurchase[]
  approvalPolicies       ApprovalPolicy[]
  ticketSlaPolicies      TicketSlaPolicy[]
  ticketEscalationRules  TicketEscalationRule[]
  scheduledActions       ScheduledAction[]
  deadLetterActions      DeadLetterAction[]
  workflowDefinitions    WorkflowDefinition[]
  workflowRuns           WorkflowRun[]
  marketplaceReviews     MarketplaceReview[]
  marketplaceRevenue     MarketplaceRevenue[]
  oauthApps              OAuthApp[]
  oauthAuthorizations    OAuthAuthorization[]
  partnerProfile         PartnerProfile?
  partnerManagedOrgs     PartnerManagedOrg[]

  @@map("organization")
}

model Member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @db.Uuid
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String   @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// ─── Custom domain models ──────────────────────────────────────────────────────

model BrandingProfile {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoUrl        String?
  accentColor    String   @default("#dc2626")
  fontFamily     String   @default("Inter")
  fontColor      String   @default("#1a1a1a")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("branding_profile")
}

model OrgDefaults {
  id             String @id @default(cuid())
  organizationId String @unique

  bankName        String?
  bankAccount     String?
  bankIFSC        String?
  taxId           String?
  gstin           String?
  businessAddress String?

  invoicePrefix     String @default("INV")
  invoiceCounter    Int    @default(1)
  voucherPrefix     String @default("VCH")
  voucherCounter    Int    @default(1)
  salarySlipPrefix  String @default("SAL")
  salarySlipCounter Int    @default(1)
  vendorBillPrefix  String @default("BILL")
  vendorBillCounter Int    @default(1)

  defaultInvoiceTemplate String @default("minimal")
  defaultVoucherTemplate String @default("minimal-office")
  defaultSlipTemplate    String @default("modern-premium")

  upiVpa       String?
  gstStateCode String?
  panNumber    String?

  // Phase 14: Portal
  portalEnabled       Boolean @default(false)
  portalHeaderMessage String?
  portalSupportEmail  String?
  portalSupportPhone  String?
  // Phase 14: Quotes
  quotePrefix         String  @default("QTE")
  quoteCounter        Int     @default(1)
  quoteValidityDays   Int     @default(14)
  quoteHeaderLabel    String  @default("QUOTE")
  // Phase 14: Dunning
  defaultDunningSeqId String?

  // Phase 15.2: i18n + Country
  defaultLanguage    String   @default("en")
  defaultDocLanguage String   @default("en")
  country            String   @default("IN")
  baseCurrency       String   @default("INR")
  timezone           String   @default("Asia/Kolkata")
  vatRegNumber       String?
  vatRate            Decimal? @db.Decimal(5, 2)
  fiscalYearStart    Int      @default(4)

  // Phase 16: SW Books
  booksEnabled                    Boolean   @default(false)
  coaTemplate                     String?
  coaSeededAt                     DateTime?
  defaultReceivableAccountId      String?
  defaultPayableAccountId         String?
  defaultBankAccountId            String?
  defaultRevenueAccountId         String?
  defaultExpenseAccountId         String?
  defaultPayrollExpenseAccountId  String?
  defaultPayrollPayableAccountId  String?
  defaultGstOutputAccountId       String?
  defaultTdsPayableAccountId      String?
  defaultGatewayClearingAccountId String?
  defaultSuspenseAccountId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_defaults")
}

// ─── Phase 16: SW Books — Accounting Foundation ────────────────────────────────

enum GlAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  CONTRA
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum AccountingStatus {
  PENDING
  POSTED
  REVERSED
}

enum RevenueRecognitionStatus {
  PENDING
  RECOGNIZED
  DEFERRED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum JournalSource {
  MANUAL
  INVOICE
  INVOICE_PAYMENT
  VOUCHER
  VENDOR_BILL
  VENDOR_BILL_PAYMENT
  SALARY_SLIP
  GST
  TDS
  BANK_RECONCILIATION
  OPENING_BALANCE
  SYSTEM_REVERSAL
}

enum FiscalPeriodStatus {
  OPEN
  LOCKED
  CLOSED
}

enum BankAccountType {
  BANK
  CASH
  PETTY_CASH
  GATEWAY_CLEARING
}

enum BankImportStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum BankTxnDirection {
  CREDIT
  DEBIT
}

enum BankTxnStatus {
  UNMATCHED
  SUGGESTED
  PARTIALLY_MATCHED
  MATCHED
  IGNORED
}

enum MatchEntityType {
  INVOICE_PAYMENT
  VENDOR_BILL_PAYMENT
  VOUCHER
  JOURNAL_ENTRY
  INTERNAL_TRANSFER
  BANK_FEE
}

model GlAccount {
  id                 String        @id @default(cuid())
  orgId              String
  code               String
  name               String
  accountType        GlAccountType
  normalBalance      NormalBalance
  parentId           String?
  description        String?
  systemKey          String?
  isSystem           Boolean       @default(false)
  isProtected        Boolean       @default(false)
  allowManualEntries Boolean       @default(true)
  isActive           Boolean       @default(true)
  sortOrder          Int           @default(0)
  archivedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  organization                Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent                      GlAccount?    @relation("GlAccountHierarchy", fields: [parentId], references: [id])
  children                    GlAccount[]   @relation("GlAccountHierarchy")
  journalLines                JournalLine[]
  bankAccounts                BankAccount[] @relation("BankAccountLedger")
  gatewayClearingBankAccounts BankAccount[] @relation("BankAccountGatewayClearing")
  vendorBills                 VendorBill[]  @relation("VendorBillExpenseAccount")

  @@unique([orgId, code])
  @@unique([orgId, systemKey])
  @@index([orgId, accountType, isActive])
  @@index([orgId, parentId])
  @@map("gl_account")
}

model FiscalPeriod {
  id                 String             @id @default(cuid())
  orgId              String
  label              String
  startDate          DateTime
  endDate            DateTime
  status             FiscalPeriodStatus @default(OPEN)
  isAdjustmentPeriod Boolean            @default(false)
  lockedAt           DateTime?
  lockedBy           String?            @db.Uuid
  reopenReason       String?
  reopenedAt         DateTime?
  reopenedBy         String?            @db.Uuid
  closedAt           DateTime?
  closedBy           String?            @db.Uuid
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  closeRuns      CloseRun[]

  @@unique([orgId, label])
  @@unique([orgId, startDate, endDate])
  @@index([orgId, status, startDate])
  @@map("fiscal_period")
}

model JournalEntry {
  id             String             @id @default(cuid())
  orgId          String
  fiscalPeriodId String
  entryNumber    String
  entryDate      DateTime
  source         JournalSource
  status         JournalEntryStatus @default(DRAFT)
  memo           String?
  sourceId       String?
  sourceRef      String?
  currency       String             @default("INR")
  totalDebit     Float              @default(0)
  totalCredit    Float              @default(0)
  isAdjustment   Boolean            @default(false)
  isReversal     Boolean            @default(false)
  reversalOfId   String?
  metadata       Json?
  createdBy      String?            @db.Uuid
  postedBy       String?            @db.Uuid
  postedAt       DateTime?
  reversedAt     DateTime?
  reversedBy     String?            @db.Uuid
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization         Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fiscalPeriod         FiscalPeriod    @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  reversalOf           JournalEntry?   @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversals            JournalEntry[]  @relation("JournalReversal")
  lines                JournalLine[]
  invoicePosted        Invoice?        @relation("InvoicePostedJournal")
  invoicePaymentPosted InvoicePayment? @relation("InvoicePaymentJournal")
  voucherPosted        Voucher?        @relation("VoucherPostedJournal")
  vendorBillPosted     VendorBill?     @relation("VendorBillJournal")
  vendorBillPaymentPosted VendorBillPayment? @relation("VendorBillPaymentJournal")
  salarySlipAccrual    SalarySlip?     @relation("SalarySlipJournal")
  salarySlipPayout     SalarySlip?     @relation("SalarySlipPayoutJournal")
  bankAccountOpening   BankAccount?    @relation("BankAccountOpeningJournal")

  @@unique([orgId, entryNumber])
  @@index([orgId, entryDate, status])
  @@index([orgId, source, sourceId])
  @@index([fiscalPeriodId, status])
  @@map("journal_entry")
}

model JournalLine {
  id                String   @id @default(cuid())
  journalEntryId    String
  orgId             String
  accountId         String
  bankTransactionId String?
  lineNumber        Int
  description       String?
  debit             Float    @default(0)
  credit            Float    @default(0)
  entityType        String?
  entityId          String?
  createdAt         DateTime @default(now())

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journalEntry    JournalEntry     @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         GlAccount        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)

  @@unique([journalEntryId, lineNumber])
  @@index([orgId, accountId])
  @@index([orgId, bankTransactionId])
  @@index([orgId, entityType, entityId])
  @@map("journal_line")
}

model BankAccount {
  id                       String          @id @default(cuid())
  orgId                    String
  glAccountId              String          @unique
  openingJournalEntryId    String?         @unique
  gatewayClearingAccountId String?
  type                     BankAccountType @default(BANK)
  name                     String
  bankName                 String?
  maskedAccountNo          String?
  ifscOrSwift              String?
  currency                 String          @default("INR")
  openingBalance           Float           @default(0)
  openingBalanceDate       DateTime?
  mappingProfile           Json?
  isPrimary                Boolean         @default(false)
  isActive                 Boolean         @default(true)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  organization           Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  glAccount              GlAccount             @relation("BankAccountLedger", fields: [glAccountId], references: [id], onDelete: Restrict)
  openingJournalEntry    JournalEntry?         @relation("BankAccountOpeningJournal", fields: [openingJournalEntryId], references: [id], onDelete: SetNull)
  gatewayClearingAccount GlAccount?            @relation("BankAccountGatewayClearing", fields: [gatewayClearingAccountId], references: [id], onDelete: SetNull)
  statementImports       BankStatementImport[]
  transactions           BankTransaction[]

  @@index([orgId, isActive])
  @@index([orgId, isPrimary])
  @@map("bank_account")
}

model BankStatementImport {
  id               String           @id @default(cuid())
  orgId            String
  bankAccountId    String
  fileName         String
  storageKey       String
  checksum         String
  sourceFormat     String           @default("csv")
  status           BankImportStatus @default(UPLOADED)
  mappingProfile   Json?
  importedRows     Int              @default(0)
  failedRows       Int              @default(0)
  errorRows        Json?
  statementStart   DateTime?
  statementEnd     DateTime?
  uploadedByUserId String?          @db.Uuid
  createdAt        DateTime         @default(now())
  completedAt      DateTime?

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@unique([bankAccountId, checksum])
  @@index([orgId, status])
  @@map("bank_statement_import")
}

model BankTransaction {
  id              String           @id @default(cuid())
  orgId           String
  bankAccountId   String
  importId        String
  txnDate         DateTime
  valueDate       DateTime?
  direction       BankTxnDirection
  amount          Float
  runningBalance  Float?
  reference       String?
  description     String
  normalizedPayee String?
  normalizedType  String?
  fingerprint     String
  rawPayload      Json?
  status          BankTxnStatus    @default(UNMATCHED)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount            @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  import       BankStatementImport    @relation(fields: [importId], references: [id], onDelete: Cascade)
  matches      BankTransactionMatch[]
  journalLines JournalLine[]

  @@unique([bankAccountId, fingerprint])
  @@index([orgId, status, txnDate])
  @@index([orgId, bankAccountId, txnDate])
  @@map("bank_transaction")
}

model BankTransactionMatch {
  id              String          @id @default(cuid())
  orgId           String
  bankTxnId       String
  entityType      MatchEntityType
  entityId        String
  matchedAmount   Float
  confidenceScore Float?
  status          String          @default("SUGGESTED")
  createdByUserId String?         @db.Uuid
  confirmedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction  @relation(fields: [bankTxnId], references: [id], onDelete: Cascade)
  invoicePayments InvoicePayment[] @relation("InvoicePaymentBankMatch")
  vendorBillPayments VendorBillPayment[] @relation("VendorBillPaymentBankMatch")

  @@unique([bankTxnId, entityType, entityId])
  @@index([orgId, status])
  @@index([entityType, entityId])
  @@map("bank_transaction_match")
}

enum VendorBillStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  OVERDUE
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum VendorBillPaymentStatus {
  PENDING
  SETTLED
  FAILED
  VOIDED
}

enum PaymentRunStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentRunItemStatus {
  PENDING
  APPROVED
  PAID
  FAILED
  SKIPPED
}

enum CloseRunStatus {
  DRAFT
  READY
  BLOCKED
  CLOSED
  REOPENED
}

enum CloseTaskStatus {
  PENDING
  PASSED
  BLOCKED
  WAIVED
}

model VendorBill {
  id               String           @id @default(cuid())
  orgId            String
  vendorId         String?
  expenseAccountId String?
  billNumber       String
  billDate         String
  dueDate          String?
  status           VendorBillStatus @default(DRAFT)
  formData         Json
  subtotalAmount   Float            @default(0)
  taxAmount        Float            @default(0)
  totalAmount      Float            @default(0)
  amountPaid       Float            @default(0)
  remainingAmount  Float            @default(0)
  currency         String           @default("INR")
  gstTotalCgst     Float            @default(0)
  gstTotalSgst     Float            @default(0)
  gstTotalIgst     Float            @default(0)
  gstTotalCess     Float            @default(0)
  notes            String?
  accountingStatus AccountingStatus @default(PENDING)
  journalEntryId   String?          @unique
  postedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  archivedAt       DateTime?

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor           Vendor?           @relation(fields: [vendorId], references: [id])
  expenseAccount   GlAccount?        @relation("VendorBillExpenseAccount", fields: [expenseAccountId], references: [id])
  lines            VendorBillLine[]
  payments         VendorBillPayment[]
  paymentRunItems  PaymentRunItem[]
  attachments      FileAttachment[]  @relation("VendorBillAttachments")
  journalEntry     JournalEntry?     @relation("VendorBillJournal", fields: [journalEntryId], references: [id])
  approvalRequests ApprovalRequest[] @relation("VendorBillApprovals")

  @@unique([orgId, billNumber])
  @@index([orgId, status])
  @@map("vendor_bill")
}

model VendorBillLine {
  id           String  @id @default(cuid())
  vendorBillId String
  description  String
  quantity     Float   @default(1)
  unitPrice    Float   @default(0)
  taxRate      Float   @default(0)
  lineTotal    Float   @default(0)
  sortOrder    Int     @default(0)

  vendorBill VendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)

  @@map("vendor_bill_line")
}

model VendorBillPayment {
  id                 String                  @id @default(cuid())
  vendorBillId       String
  orgId              String
  paymentRunId       String?
  amount             Float
  currency           String                  @default("INR")
  paidAt             DateTime                @default(now())
  method             String?
  note               String?
  source             String                  @default("admin_manual")
  status             VendorBillPaymentStatus @default(SETTLED)
  externalPaymentId  String?
  externalReferenceId String?
  externalPayload    Json?
  recordedByUserId   String?                 @db.Uuid
  accountingStatus   AccountingStatus        @default(PENDING)
  journalEntryId     String?                 @unique
  bankMatchId        String?
  clearingAccountId  String?
  accountingPostedAt DateTime?
  createdAt          DateTime                @default(now())

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendorBill   VendorBill            @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)
  paymentRun   PaymentRun?           @relation(fields: [paymentRunId], references: [id], onDelete: SetNull)
  journalEntry JournalEntry?         @relation("VendorBillPaymentJournal", fields: [journalEntryId], references: [id])
  bankMatch    BankTransactionMatch? @relation("VendorBillPaymentBankMatch", fields: [bankMatchId], references: [id])
  paymentRunItem PaymentRunItem?     @relation("PaymentRunItemPayment")

  @@index([vendorBillId])
  @@index([externalPaymentId])
  @@map("vendor_bill_payment")
}

model PaymentRun {
  id               String            @id @default(cuid())
  orgId            String
  runNumber        String
  scheduledDate    DateTime
  status           PaymentRunStatus  @default(DRAFT)
  totalAmount      Float             @default(0)
  notes            String?
  requestedByUserId String?          @db.Uuid
  approvedAt       DateTime?
  approvedByUserId String?           @db.Uuid
  executedAt       DateTime?
  executedByUserId String?           @db.Uuid
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  items            PaymentRunItem[]
  payments         VendorBillPayment[]
  approvalRequests ApprovalRequest[] @relation("PaymentRunApprovals")

  @@unique([orgId, runNumber])
  @@index([orgId, status])
  @@map("payment_run")
}

model PaymentRunItem {
  id               String               @id @default(cuid())
  paymentRunId     String
  vendorBillId     String
  proposedAmount   Float
  approvedAmount   Float?
  status           PaymentRunItemStatus @default(PENDING)
  executedPaymentId String?            @unique
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  paymentRun     PaymentRun        @relation(fields: [paymentRunId], references: [id], onDelete: Cascade)
  vendorBill     VendorBill        @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)
  executedPayment VendorBillPayment? @relation("PaymentRunItemPayment", fields: [executedPaymentId], references: [id])

  @@unique([paymentRunId, vendorBillId])
  @@index([vendorBillId, status])
  @@map("payment_run_item")
}

model CloseRun {
  id               String         @id @default(cuid())
  orgId            String
  fiscalPeriodId   String
  status           CloseRunStatus @default(DRAFT)
  blockerCount     Int            @default(0)
  summary          Json?
  notes            String?
  startedAt        DateTime       @default(now())
  startedByUserId  String?        @db.Uuid
  completedAt      DateTime?
  completedByUserId String?       @db.Uuid
  reopenedAt       DateTime?
  reopenedByUserId String?        @db.Uuid
  reportSnapshotId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  tasks        CloseTask[]

  @@unique([orgId, fiscalPeriodId])
  @@index([orgId, status])
  @@map("close_run")
}

model CloseTask {
  id          String          @id @default(cuid())
  closeRunId  String
  orgId       String
  code        String
  label       String
  description String?
  status      CloseTaskStatus @default(PENDING)
  severity    String          @default("blocker")
  blockerReason String?
  metadata    Json?
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  closeRun      CloseRun      @relation(fields: [closeRunId], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([closeRunId, code])
  @@index([orgId, status])
  @@map("close_task")
}

// ─── Master Data Models ─────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  taxId          String?
  gstin          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paymentHealthScore Int     @default(100)
  preferredLanguage  String?

  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  virtualAccounts  CustomerVirtualAccount[]
  dunningOptOuts   DunningOptOut[]
  portalTokens     CustomerPortalToken[]
  portalAccessLogs CustomerPortalAccessLog[]
  statements       CustomerStatement[]
  quotes           Quote[]
  arrangements     PaymentArrangement[]

  @@index([organizationId])
  @@map("customer")
}

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  taxId          String?
  gstin          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]
  bills        VendorBill[]

  @@index([organizationId])
  @@map("vendor")
}

model Employee {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  employeeId     String?
  designation    String?
  department     String?
  bankName       String?
  bankAccount    String?
  bankIFSC       String?
  panNumber      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salarySlips  SalarySlip[]

  @@index([organizationId])
  @@map("employee")
}

// ─── Phase 15: GST & e-Invoicing Enums ──────────────────────────────────────

enum TdsSection {
  SECTION_194A
  SECTION_194C
  SECTION_194J
  SECTION_194H
  SECTION_194I
  SECTION_194Q
  OTHER
}

enum TdsCertStatus {
  PENDING_CERT
  CERT_RECEIVED
  FILED
}

enum GstType {
  INTRASTATE
  INTERSTATE
  EXEMPT
}

// ─── Document Models ────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  VIEWED
  DUE
  PARTIALLY_PAID
  PAID
  OVERDUE
  DISPUTED
  CANCELLED
  REISSUED
  ARRANGEMENT_MADE
}

model Invoice {
  id                     String        @id @default(cuid())
  organizationId         String
  customerId             String?
  invoiceNumber          String
  invoiceDate            String
  dueDate                String?
  status                 InvoiceStatus @default(DRAFT)
  formData               Json
  totalAmount            Float         @default(0)
  notes                  String?
  originalId             String?
  issuedAt               DateTime?
  paidAt                 DateTime?
  overdueAt              DateTime?
  reissueReason          String?
  razorpayPaymentLinkId  String?
  razorpayPaymentLinkUrl String?
  paymentLinkExpiresAt   DateTime?
  // Payment reconciliation snapshot fields (derived, maintained by reconciliation service)
  amountPaid             Float         @default(0)
  remainingAmount        Float         @default(0)
  lastPaymentAt          DateTime?
  lastPaymentMethod      String?
  paymentPromiseDate     String?
  paymentLinkStatus      String?
  paymentLinkLastEventAt DateTime?
  // Phase 14: Dunning
  dunningEnabled         Boolean       @default(true)
  dunningPausedUntil     DateTime?
  dunningSequenceId      String?
  // Phase 15: GST & e-Invoicing
  supplierGstin          String?
  customerGstin          String?
  placeOfSupply          String?
  reverseCharge          Boolean       @default(false)
  exportType             String?
  gstTotalCgst           Float         @default(0)
  gstTotalSgst           Float         @default(0)
  gstTotalIgst           Float         @default(0)
  gstTotalCess           Float         @default(0)
  irnNumber              String?
  irnAckNumber           String?
  irnAckDate             DateTime?
  irnQrCode              String?       @db.Text
  eWayBillNumber         String?
  eWayBillDate           DateTime?
  eWayBillExpiry         DateTime?
  ewbTransportMode       String?
  ewbVehicleNumber       String?
  ewbTransporterGstin    String?
  ewbTransportDocNo      String?
  ewbDistanceKm          Int?
  ewbFromPincode         String?
  ewbToPincode           String?

  // Phase 15.2: Multi-currency + i18n
  displayCurrency          String?
  exchangeRate             Float?
  displayTotalAmount       Float?
  exchangeRateDate         DateTime?
  documentLanguage         String                   @default("en")
  accountingStatus         AccountingStatus         @default(PENDING)
  revenueRecognitionStatus RevenueRecognitionStatus @default(PENDING)
  postedJournalEntryId     String?                  @unique
  accountingPostedAt       DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer            Customer?             @relation(fields: [customerId], references: [id])
  original            Invoice?              @relation("InvoiceReissue", fields: [originalId], references: [id])
  reissues            Invoice[]             @relation("InvoiceReissue")
  lineItems           InvoiceLineItem[]
  attachments         FileAttachment[]      @relation("InvoiceAttachments")
  stateEvents         InvoiceStateEvent[]
  payments            InvoicePayment[]
  proofs              InvoiceProof[]
  publicTokens        PublicInvoiceToken[]
  tickets             InvoiceTicket[]
  scheduledSends      ScheduledSend[]
  recurringRule       RecurringInvoiceRule? @relation("RecurringBase")
  generatedFrom       RecurringInvoiceRule? @relation("RecurringGenerated", fields: [generatedFromRuleId], references: [id])
  generatedFromRuleId String?
  approvalRequests    ApprovalRequest[]     @relation("InvoiceApprovals")
  dunningLogs         DunningLog[]
  arrangement         PaymentArrangement?
  postedJournalEntry  JournalEntry?         @relation("InvoicePostedJournal", fields: [postedJournalEntryId], references: [id])
  tdsRecords          TdsRecord[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@map("invoice")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  taxRate     Float   @default(0)
  discount    Float   @default(0)
  amount      Float   @default(0)
  sortOrder   Int     @default(0)
  // Phase 15: GST
  hsnCode     String?
  sacCode     String?
  gstRate     Float   @default(0)
  gstType     GstType @default(INTRASTATE)
  cgstAmount  Float   @default(0)
  sgstAmount  Float   @default(0)
  igstAmount  Float   @default(0)
  cessAmount  Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_item")
}

model Voucher {
  id               String           @id @default(cuid())
  organizationId   String
  vendorId         String?
  voucherNumber    String
  voucherDate      String
  type             String           @default("payment")
  status           String           @default("draft")
  formData         Json
  totalAmount      Float            @default(0)
  isMultiLine      Boolean          @default(false)
  documentLanguage String           @default("en")
  accountingStatus AccountingStatus @default(PENDING)
  journalEntryId   String?          @unique
  postedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  archivedAt       DateTime?

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor           Vendor?           @relation(fields: [vendorId], references: [id])
  lines            VoucherLine[]
  attachments      FileAttachment[]  @relation("VoucherAttachments")
  journalEntry     JournalEntry?     @relation("VoucherPostedJournal", fields: [journalEntryId], references: [id])
  approvalRequests ApprovalRequest[] @relation("VoucherApprovals")

  @@unique([organizationId, voucherNumber])
  @@index([organizationId, status])
  @@map("voucher")
}

model VoucherLine {
  id          String  @id @default(cuid())
  voucherId   String
  description String
  date        String?
  time        String?
  amount      Float   @default(0)
  category    String?
  sortOrder   Int     @default(0)

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@map("voucher_line")
}

model SalarySlip {
  id                   String           @id @default(cuid())
  organizationId       String
  employeeId           String?
  slipNumber           String
  month                Int
  year                 Int
  status               String           @default("draft")
  formData             Json
  grossPay             Float            @default(0)
  netPay               Float            @default(0)
  documentLanguage     String           @default("en")
  accountingStatus     AccountingStatus @default(PENDING)
  journalEntryId       String?          @unique
  payoutJournalEntryId String?          @unique
  postedAt             DateTime?
  payoutPostedAt       DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  archivedAt           DateTime?

  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee           Employee?         @relation(fields: [employeeId], references: [id])
  components         SalaryComponent[]
  attachments        FileAttachment[]  @relation("SalarySlipAttachments")
  journalEntry       JournalEntry?     @relation("SalarySlipJournal", fields: [journalEntryId], references: [id])
  payoutJournalEntry JournalEntry?     @relation("SalarySlipPayoutJournal", fields: [payoutJournalEntryId], references: [id])
  approvalRequests   ApprovalRequest[] @relation("SalarySlipApprovals")

  @@unique([organizationId, slipNumber])
  @@index([organizationId, status])
  @@map("salary_slip")
}

model SalaryComponent {
  id           String @id @default(cuid())
  salarySlipId String
  label        String
  amount       Float  @default(0)
  type         String
  sortOrder    Int    @default(0)

  salarySlip SalarySlip @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)

  @@map("salary_component")
}

model FileAttachment {
  id             String   @id @default(cuid())
  organizationId String
  entityType     String
  entityId       String
  fileName       String
  storageKey     String
  mimeType       String
  size           Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invoice    Invoice?    @relation("InvoiceAttachments", fields: [entityId], references: [id], map: "file_attachment_invoice_fkey")
  voucher    Voucher?    @relation("VoucherAttachments", fields: [entityId], references: [id], map: "file_attachment_voucher_fkey")
  vendorBill VendorBill? @relation("VendorBillAttachments", fields: [entityId], references: [id], map: "file_attachment_vendor_bill_fkey")
  salarySlip SalarySlip? @relation("SalarySlipAttachments", fields: [entityId], references: [id], map: "file_attachment_salary_slip_fkey")

  @@index([organizationId, entityType, entityId])
  @@map("file_attachment")
}

model SalaryPreset {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  components     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("salary_preset")
}

// ─── Phase 4: SW Pay — Invoice Lifecycle ──────────────────────────────────────

model InvoiceStateEvent {
  id         String   @id @default(cuid())
  invoiceId  String
  fromStatus String
  toStatus   String
  actorId    String?  @db.Uuid
  actorName  String?
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_state_event")
}

model InvoicePayment {
  id                     String           @id @default(cuid())
  invoiceId              String
  orgId                  String
  amount                 Float
  currency               String           @default("INR")
  paidAt                 DateTime         @default(now())
  method                 String?
  note                   String?
  isPartial              Boolean          @default(false)
  // Reconciliation fields
  source                 String           @default("admin_manual")
  status                 String           @default("SETTLED")
  externalPaymentId      String?
  externalReferenceId    String?
  externalPayload        Json?
  paymentMethodDisplay   String?
  paymentChannel         String?
  plannedNextPaymentDate String?
  recordedByUserId       String?          @db.Uuid
  reviewedByUserId       String?          @db.Uuid
  reviewedAt             DateTime?
  rejectionReason        String?
  accountingStatus       AccountingStatus @default(PENDING)
  journalEntryId         String?          @unique
  bankMatchId            String?
  clearingAccountId      String?
  accountingPostedAt     DateTime?
  createdAt              DateTime         @default(now())

  invoice      Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  proof        InvoiceProof?         @relation("PaymentProof")
  installment  PaymentInstallment?
  journalEntry JournalEntry?         @relation("InvoicePaymentJournal", fields: [journalEntryId], references: [id])
  bankMatch    BankTransactionMatch? @relation("InvoicePaymentBankMatch", fields: [bankMatchId], references: [id])

  @@index([invoiceId])
  @@index([externalPaymentId])
  @@map("invoice_payment")
}

enum ProofReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model InvoiceProof {
  id                     String            @id @default(cuid())
  invoiceId              String
  invoicePaymentId       String?           @unique
  fileUrl                String
  fileName               String
  amount                 Float             @default(0)
  paymentDate            String?
  paymentMethod          String?
  plannedNextPaymentDate String?
  uploadedByToken        String?
  uploadedByUserId       String?           @db.Uuid
  reviewStatus           ProofReviewStatus @default(PENDING)
  reviewNote             String?
  reviewedById           String?           @db.Uuid
  reviewedAt             DateTime?
  createdAt              DateTime          @default(now())

  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoicePayment InvoicePayment? @relation("PaymentProof", fields: [invoicePaymentId], references: [id])

  @@index([invoiceId])
  @@map("invoice_proof")
}

model PublicInvoiceToken {
  id             String    @id @default(cuid())
  invoiceId      String
  orgId          String
  token          String    @unique @default(cuid())
  expiresAt      DateTime?
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("public_invoice_token")
}

// ─── Phase 5: SW Flow — Ticketing ─────────────────────────────────────────────

enum TicketCategory {
  BILLING_QUERY
  AMOUNT_DISPUTE
  MISSING_ITEM
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
enum ApprovalPolicyStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalStepMode {
  SINGLE
  SEQUENTIAL
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketSeverity {
  INFORMATIONAL
  BLOCKING
  FINANCE_CRITICAL
  CUSTOMER_ESCALATED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
  CANCELLED
}

enum ScheduledActionStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
  CANCELLED
}

model InvoiceTicket {
  id             String         @id @default(cuid())
  invoiceId      String
  orgId          String
  submitterToken String?
  submitterName  String
  submitterEmail String
  category       TicketCategory @default(OTHER)
  description    String
  status         TicketStatus   @default(OPEN)
  assigneeId     String?        @db.Uuid
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?
  priority            TicketPriority @default(NORMAL)
  severity            TicketSeverity @default(INFORMATIONAL)
  dueAt               DateTime?
  firstResponseDueAt  DateTime?
  resolutionDueAt     DateTime?
  firstRespondedAt    DateTime?
  breachedAt          DateTime?
  breachType          String?
  escalationLevel     Int            @default(0)
  sourceModule        String?

  invoice Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([invoiceId])
  @@index([orgId, status])
  @@map("invoice_ticket")
}

model TicketReply {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?  @db.Uuid
  authorName String
  isInternal Boolean  @default(false)
  message    String
  createdAt  DateTime @default(now())

  ticket InvoiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_reply")
}

// ─── Phase 5: SW Flow — Approvals ─────────────────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
model ApprovalPolicy {
  id                String               @id @default(cuid())
  orgId             String
  name              String
  module            String
  eventType         String
  status            ApprovalPolicyStatus @default(ACTIVE)
  stepMode          ApprovalStepMode     @default(SINGLE)
  escalateAfterMins Int?
  createdBy         String               @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, module, status])
  @@map("approval_policy")
}

model ApprovalPolicyRule {
  id                 String   @id @default(cuid())
  policyId           String
  sequence           Int
  minAmount          Decimal? @db.Decimal(14, 2)
  maxAmount          Decimal? @db.Decimal(14, 2)
  approverRole       String?
  approverUserId     String?  @db.Uuid
  fallbackRole       String?
  fallbackUserId     String?  @db.Uuid
  createdAt          DateTime @default(now())

  @@index([policyId, sequence])
  @@map("approval_policy_rule")
}

model TicketSlaPolicy {
  id                     String   @id @default(cuid())
  orgId                  String
  name                   String
  category               String?
  priority               String?
  firstResponseTargetMins Int
  resolutionTargetMins   Int
  businessHoursOnly      Boolean  @default(false)
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isDefault])
  @@map("ticket_sla_policy")
}

model TicketEscalationRule {
  id               String   @id @default(cuid())
  orgId            String
  name             String
  breachType       String
  afterMins        Int
  targetRole       String?
  targetUserId     String?  @db.Uuid
  notifyOrgAdmins  Boolean  @default(false)
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, breachType])
  @@map("ticket_escalation_rule")
}

model ScheduledAction {
  id               String                @id @default(cuid())
  orgId            String
  actionType       String
  sourceModule     String
  sourceEntityType String?
  sourceEntityId   String?
  workflowRunId    String?
  payload          Json
  status           ScheduledActionStatus @default(PENDING)
  scheduledAt      DateTime
  attemptCount     Int                   @default(0)
  maxAttempts      Int                   @default(3)
  nextRetryAt      DateTime?
  lastError        String?
  createdAt        DateTime              @default(now())
  completedAt      DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status, scheduledAt])
  @@index([nextRetryAt, status])
  @@map("scheduled_action")
}

model DeadLetterAction {
  id                String   @id @default(cuid())
  scheduledActionId String   @unique
  orgId             String
  actionType        String
  sourceModule      String
  failureReason     String
  payload           Json
  deadLetteredAt    DateTime @default(now())
  resolvedAt        DateTime?
  resolvedBy        String?  @db.Uuid

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, deadLetteredAt])
  @@map("dead_letter_action")
}

model WorkflowDefinition {
  id          String         @id @default(cuid())
  orgId       String
  name        String
  description String?
  triggerType String
  status      WorkflowStatus @default(DRAFT)
  version     Int            @default(1)
  config      Json
  createdBy   String         @db.Uuid
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  steps        WorkflowStep[]
  runs         WorkflowRun[]

  @@index([orgId, status])
  @@map("workflow_definition")
}

model WorkflowStep {
  id         String   @id @default(cuid())
  workflowId String
  sequence   Int
  actionType String
  config     Json
  createdAt  DateTime @default(now())

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepRuns WorkflowStepRun[]

  @@index([workflowId, sequence])
  @@map("workflow_step")
}

model WorkflowRun {
  id               String            @id @default(cuid())
  workflowId       String
  orgId            String
  triggerType      String
  sourceModule     String
  sourceEntityType String?
  sourceEntityId   String?
  actorId          String?           @db.Uuid
  status           WorkflowRunStatus @default(PENDING)
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  failureReason    String?

  workflow     WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stepRuns     WorkflowStepRun[]

  @@index([orgId, status, startedAt])
  @@index([sourceModule, sourceEntityId])
  @@map("workflow_run")
}

model WorkflowStepRun {
  id              String            @id @default(cuid())
  workflowRunId   String
  workflowStepId  String
  status          WorkflowRunStatus @default(PENDING)
  attemptCount    Int               @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  failureReason   String?
  outputPayload   Json?

  workflowRun  WorkflowRun  @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflowStep WorkflowStep @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)

  @@index([workflowRunId, status])
  @@map("workflow_step_run")
}

model ApprovalRequest {
  id              String         @id @default(cuid())
  docType         String
  docId           String
  orgId           String
  requestedById   String         @db.Uuid
  requestedByName String?
  approverId      String?        @db.Uuid
  approverName    String?
  status          ApprovalStatus @default(PENDING)
  note            String?
  createdAt       DateTime       @default(now())
  decidedAt       DateTime?
  policyId           String?
  policyRuleId       String?
  dueAt              DateTime?
  escalatedAt        DateTime?
  escalationLevel    Int            @default(0)
  lastReminderAt     DateTime?

  invoice    Invoice?    @relation("InvoiceApprovals", fields: [docId], references: [id], map: "approval_invoice_fkey")
  voucher    Voucher?    @relation("VoucherApprovals", fields: [docId], references: [id], map: "approval_voucher_fkey")
  vendorBill VendorBill? @relation("VendorBillApprovals", fields: [docId], references: [id], map: "approval_vendor_bill_fkey")
  paymentRun PaymentRun? @relation("PaymentRunApprovals", fields: [docId], references: [id], map: "approval_payment_run_fkey")
  salarySlip SalarySlip? @relation("SalarySlipApprovals", fields: [docId], references: [id], map: "approval_salary_slip_fkey")

  @@index([orgId, status])
  @@index([docType, docId])
  @@map("approval_request")
}

// ─── Phase 5: SW Flow — Notifications ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  orgId     String
  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  category      String?
  severity      String?
  sourceModule  String?
  sourceRef     String?
  // Sprint 18.2 delivery extensions
  emailRequested Boolean @default(false)
  recipientEmail String?

  deliveries NotificationDelivery[]

  @@index([userId, isRead])
  @@index([orgId])
  @@map("notification")
}

// ─── Phase 18 Sprint 18.2: Notification Delivery ─────────────────────────────

enum NotificationDeliveryStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  TERMINAL_FAILURE
  REPLAYED
}

enum NotificationDeliveryChannel {
  in_app
  email
}

model NotificationDelivery {
  id                String                      @id @default(cuid())
  notificationId    String
  orgId             String
  channel           NotificationDeliveryChannel
  recipientTarget   String
  status            NotificationDeliveryStatus  @default(QUEUED)
  attemptCount      Int                         @default(0)
  maxAttempts       Int                         @default(3)
  provider          String?
  providerRef       String?
  sourceModule      String?
  sourceRef         String?
  workflowRunId     String?
  scheduledActionId String?
  queuedAt          DateTime                    @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  nextRetryAt       DateTime?
  failureReason     String?
  replayedFromId    String?
  replayedAt        DateTime?
  replayedBy        String?                     @db.Uuid

  notification  Notification         @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  replayedFrom  NotificationDelivery?  @relation("DeliveryReplay", fields: [replayedFromId], references: [id], onDelete: SetNull)
  replays       NotificationDelivery[] @relation("DeliveryReplay")

  @@index([orgId, status])
  @@index([orgId, channel])
  @@index([notificationId])
  @@index([nextRetryAt, status])
  @@index([orgId, sourceModule])
  @@map("notification_delivery")
}

